import speech_recognition as sr
import pyaudio

keywords_hera = ["era", "Era", "Hera", "hera", "Terror", "Cara", "hella"]
keywords_speech = ["speech recognition", "which recognition", "speech", "recognition", "a speech recognition"]

def record_audio():
    r = sr.Recognizer()
    with sr.Microphone() as source:
        print("Listening...")
        audio = r.listen(source, phrase_time_limit=3)
        return audio

def transcribe_audio(audio):
    r = sr.Recognizer()
    try:
        text = r.recognize_google(audio, language="en-US")
        return text
    except sr.UnknownValueError:
        print("Sorry, I could not understand what you said.")
        return None


def recognize_alias():
    audio = record_audio()
    text = transcribe_audio(audio)
    if text in keywords_hera:
        print("yes")
        return True

def start_task():
    audio = record_audio()
    text = transcribe_audio(audio)
    if text in keywords_speech:
        print("starting speech recognition task")
        return True
    else:
        return False

while True:
    recognize_alias()
    start_task()
    if recognize_alias() == True:
        start_task()