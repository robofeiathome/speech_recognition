import speech_recognition as sr
import pyaudio

keywords_hera = ["era", "Era", "Hera", "hera"]
keywords_speech = ["speech recognition", "which recognition", "speech", "recognition"]

def record_audio():
    r = sr.Recognizer()
    with sr.Microphone() as source:
        print("Listening...")
        audio = r.listen(source, phrase_time_limit=3)
        return audio

def transcribe_audio(audio):
    r = sr.Recognizer()
    try:
        text = r.recognize_google(audio, language="en-US", show_all=True)
        return text
    except sr.UnknownValueError:
        print("Sorry, I could not understand what you said.")
        return None


def recognize_alias():
    audio = record_audio()
    text = transcribe_audio(audio)
    for alternative in text['alternative']:
        if alternative['transcript'] in keywords_hera:
            print("yes")
            return True

def start_task():
    audio = record_audio()
    text = transcribe_audio(audio)
    for alternative in text['alternative']:
        for word in keywords_speech:
            if word in alternative['transcript']:
                print("starting speech recognition task")
                return True
            else:
                return False

while True:
    if(recognize_alias()):
        while start_task() != True:
            continue
    else:
