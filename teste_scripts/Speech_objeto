import speech_recognition as sr
import pyaudio

keywords_hera = ["era", "Era", "Hera", "hera"]
keywords_speech = ["speech recognition", "which recognition"]

def record_audio():
    r = sr.Recognizer()
    with sr.Microphone() as source:
        print("Listening...")
        audio = r.listen(source, phrase_time_limit=3)
        return audio

def transcribe_audio(audio):
    r = sr.Recognizer()
    try:
        text = r.recognize_google(audio, language="en-US")
        return text
    except sr.UnknownValueError:
        print("Sorry, I could not understand what you said.")
        return None

while True:
    audio = record_audio()
    text = transcribe_audio(audio)
    if text in keywords_hera:
        print("yes")
        break

while True:
    audio = record_audio()
    text = transcribe_audio(audio)
    if text in keywords_speech:
        print("starting speech recognition task")
        break

