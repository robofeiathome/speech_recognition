import speech_recognition as sr

rec = sr.Recognizer()

with sr.Microphone(1) as microfone:
    rec.adjust_for_ambient_noise(microfone)
    print("Pode começar a falar:")
    rec.pause_threshold = 0.8
    audio = rec.listen(microfone)
    try:
        # texto = rec.recognize_google(audio_data=audio, language="en-US")
        texto = rec.recognize_whisper(model="medium",audio_data=audio, language="english")
        print(texto)
    except:
        print("Não consegui escutar")


